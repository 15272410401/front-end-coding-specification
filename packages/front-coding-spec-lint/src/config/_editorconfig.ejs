# 表示这是根配置文件，不再向上查找
root = true

# 所有文件适用
[*]
# 缩进风格（space/tab）
indent_style = space
# 缩进大小（空格数）
indent_size = 2
# 换行符（lf/crlf/cr）
end_of_line = lf
# 字符编码
charset = utf-8
# 删除行尾空格
trim_trailing_whitespace = true
# 文件末尾添加空行
insert_final_newline = true
# 引号类型（single/double）
quote_type = single

# Markdown 文件适用
[*.md]
# 保留行尾空格（Markdown 需要）
trim_trailing_whitespace = false
