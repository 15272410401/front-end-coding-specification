{
  "name": "front-coding-spec-lint",
  "version": "0.0.2-alpha.0",
  "description": "一个关于前端编码规范的 CLI 工具，用于创建或接入前端项目的编码规范配置",
  "license": "ISC",
  "author": "hechenglong <1104907547@qq.com>",
  "bin": "./lib/cli.js",
  "main": "./lib/index.js",
  "files": [
    "lib/"
  ],
  "keywords": [
    "front-end",
    "lint",
    "cli"
  ],
  "scripts": {
    "dev": "npm run copyfiles && tsc -w",
    "build": "rimraf lib && npm run copyfiles && tsc",
    "copyfiles": "copyfiles -a -u 1 \"src/config/**\" lib",
    "test": "npm run build && mocha ./__tests__/*.test.js --timeout 10000",
    "coverage": "nyc mocha ./__tests__/*.test.js --timeout 10000",
    "prepublishOnly": "npm run test"
  },
  "publishConfig": {
    "registry": "https://registry.npmmirror.com",
    "access": "public"
  },
  "homepage": "https://github.com/15272410401/front-end-coding-specification#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/15272410401/front-end-coding-specification.git"
  },
  "bugs": {
    "url": "https://github.com/15272410401/front-end-coding-specification/issues"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/eslint-parser": "^7.24.5",
    "@commitlint/cli": "^21.1.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "chalk": "^5.6.2",
    "command-exists": "^1.2.9",
    "commander": "^15.0.0",
    "commitlint-config-hcl": "workspace:*",
    "cross-spawn": "^7.0.6",
    "ejs": "^6.0.1",
    "eslint": "^9.39.5",
    "eslint-config-hcl": "workspace:*",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-vue": "^9.33.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.6",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "is-docker": "^4.0.0",
    "lodash": "^4.18.1",
    "markdownlint": "^0.41.0",
    "markdownlint-config-hcl": "workspace:*",
    "markdownlint-rule-helpers": "^0.31.0",
    "ora": "^9.4.1",
    "prettier": "3.9.5",
    "strip-ansi": "^7.2.0",
    "stylelint": "^17.14.0",
    "stylelint-config-hcl": "workspace:*",
    "stylelint-scss": "^7.2.0",
    "terminal-link": "^5.0.0",
    "text-table": "^0.2.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/cross-spawn": "^6.0.6",
    "@types/ejs": "^3.1.5",
    "@types/eslint": "^9.6.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/markdownlint-rule-helpers": "^0.21.6",
    "@types/node": "^26.1.1",
    "@types/prettier": "^3.0.0",
    "@types/stylelint": "^14.0.0",
    "@types/text-table": "^0.2.5",
    "chai": "^6.2.2",
    "copyfiles": "^2.4.1",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
